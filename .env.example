# Copy to .env and adjust as needed
DATABASE_URL=postgres://kanto:kanto_dev@localhost:5433/kanto
# Generate with: openssl rand -base64 32  (or npx auth secret)
AUTH_SECRET=change-me

# Telegram capture bot (optional). Create a bot via @BotFather, then register
# the webhook: npx tsx scripts/set-telegram-webhook.ts https://your-host
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
